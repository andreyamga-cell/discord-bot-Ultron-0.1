            await ctx.send("❌ Неверный формат времени. Используйте: 30s, 30m, 2h, 1d")
            return
            
        total_seconds = time_value * time_units[time_unit]
        end_time = datetime.now() + timedelta(seconds=total_seconds)
        
    except (ValueError, IndexError):
        await ctx.send("❌ Неверный формат времени. Используйте: 30s, 30m, 2h, 1d")
        return
    
    current_level = 1
