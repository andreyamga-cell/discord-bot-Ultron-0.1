def save_warnings():
    try:
        serializable_warnings = {}
        for user_id, warnings in active_warnings.items():
            serializable_warnings[user_id] = []
            for w in warnings:
                serializable_warnings[user_id].append({
                    'level': w['level'],
                    'end_time': w['end_time'].isoformat() if isinstance(w['end_time'], datetime) else w['end_time'],
                    'reason': w['reason'],
                    'role_name': w['role_name'],
                    'issued_by': w['issued_by'],
                    'issued_at': w['issued_at'].isoformat() if isinstance(w['issued_at'], datetime) else w['issued_at'],
                    'warning_id': w['warning_id'],
                    'had_admin': w.get('had_admin', False)
                })
        with open(WARNINGS_FILE, 'wb') as f:
            pickle.dump(serializable_warnings, f)
        logger.info("Предупреждения сохранены в файл")
    except Exception as e:
        logger.error(f"Ошибка сохранения предупреждений: {e}")

def load_warnings():
    global active_warnings
    try:
        if os.path.exists(WARNINGS_FILE):
            with open(WARNINGS_FILE, 'rb') as f:
                data = pickle.load(f)
                for user_id, warnings in data.items():
                    active_warnings[int(user_id)] = []
                    for w in warnings:
                        active_warnings[int(user_id)].append({
                            'level': w['level'],
                            'end_time': datetime.fromisoformat(w['end_time']) if isinstance(w['end_time'], str) else w['end_time'],
                            'reason': w['reason'],
                            'role_name': w['role_name'],
                            'issued_by': w['issued_by'],
                            'issued_at': datetime.fromisoformat(w['issued_at']) if isinstance(w['issued_at'], str) else w['issued_at'],
                            'warning_id': w['warning_id'],
                            'had_admin': w.get('had_admin', False)
                        })
            logger.info("Предупреждения загружены из файла")
    except Exception as e:
        logger.error(f"Ошибка загрузки предупреждений: {e}")

