            )
            
            await interaction.response.send_message(embed=embed, view=view, ephemeral=True)
        
        return callback
    
    async def add_player_with_character(self, interaction, role_key, character_name):
        if self.message_id not in farm_messages:
            await interaction.response.send_message("❌ Этот лист фарма больше не активен", ephemeral=True)
            return
        
        event_data = farm_messages[self.message_id]['data']
        farm_config = FARM_TYPES[self.farm_type]
        
        max_limit = farm_config['roles'][role_key]['limit']
        current_list = event_data[role_key]
        
        if len(current_list) >= max_limit:
            await interaction.response.send_message(f"❌ Список уже заполнен ({max_limit}/{max_limit})", ephemeral=True)
            return
        
        for role_list in event_data.values():
            for entry in role_list:
                if entry['user'].id == self.target_member.id:
                    await interaction.response.send_message(f"❌ {self.target_member.mention} уже записан на фарм!", ephemeral=True)
                    return
        
        current_list.append({
            'user': self.target_member,
            'character': character_name
        })
        
        try:
            channel = interaction.channel
            if not isinstance(channel, discord.Thread):
                for msg_id, farm_data in farm_messages.items():
                    if msg_id == self.message_id:
                        thread_id = farm_data.get('thread_id')
                        if thread_id:
                            channel = bot.get_channel(thread_id)
                        break
            
            if channel:
                message = await channel.fetch_message(self.message_id)
                await update_farm_message(message, event_data, self.farm_type)
            
            role_display = farm_config['roles'][role_key]['display_name']
            await interaction.response.send_message(f"✅ {self.target_member.mention} добавлен как **{role_display}** на персонаже **{character_name}**", ephemeral=True)
            
            save_farm_data()
            
            logger.info(f"Создатель фарма {self.creator} добавил {self.target_member} как {role_display} ({character_name})")
            
            await log_farm_action(
                interaction.guild,
                'join',
                self.target_member,
                character_name,
                role_display,
                self.farm_type,
                farm_config['name']
            )
            
            try:
                await self.target_member.send(f"📝 Вы были добавлены в фарм **{farm_config['name']}** на роль **{role_display}** с персонажем **{character_name}**")
            except:
                pass
            
        except discord.NotFound:
            await interaction.response.send_message("❌ Сообщение фарма не найдено", ephemeral=True)
        except Exception as e:
            logger.error(f"Ошибка при добавлении на фарм: {e}")
            await interaction.response.send_message("❌ Произошла ошибка при добавлении", ephemeral=True)
    
    async def cancel_callback(self, interaction: discord.Interaction):
        if interaction.user.id != self.creator.id:
            await interaction.response.send_message("❌ Это меню не для вас!", ephemeral=True)
            return
        await interaction.response.edit_message(content="❌ Добавление отменено", view=None)
    
    def get_filtered_characters(self, role_type, farm_type):
        characters = CHARACTERS[role_type].copy()
        
        if farm_type in SPECIAL_CHARACTERS and role_type in SPECIAL_CHARACTERS[farm_type]:
            characters.extend(SPECIAL_CHARACTERS[farm_type][role_type])
        
        characters = list(dict.fromkeys(characters))
        
        banned_chars = BANNED_CHARACTERS.get(farm_type, [])
        characters = [char for char in characters if char not in banned_chars]
        
        return characters

@bot.command(name='removefarm')
async def remove_from_farm_command(ctx, member: discord.Member = None):
    if not is_farm_creator(ctx):
        embed = discord.Embed(
            title="❌ Ошибка",
            description="У вас нет прав для использования этой команды! Требуется роль создателя фарма.",
            color=0xff0000
        )
        await ctx.send(embed=embed)
        return
    
    if not member:
        await ctx.send("❌ Укажите пользователя: `!removefarm @пользователь`")
        return
    
    current_channel = ctx.channel
    if not isinstance(current_channel, discord.Thread):
        await ctx.send("❌ Эта команда работает только в тредах сборов!")
        return
    
    farm_message_id = None
    farm_type = None
    for msg_id, farm_data in farm_messages.items():
        if farm_data.get('thread_id') == current_channel.id:
            farm_message_id = msg_id
            farm_type = farm_data['type']
            break
    
    if not farm_message_id:
        await ctx.send("❌ Не найден активный лист фарма в этом треде!")
        return
    
    event_data = farm_messages[farm_message_id]['data']
    removed, removed_from, removed_data = await remove_specific_user_from_farm(event_data, member)
    
    if removed:
        try:
            message = await ctx.channel.fetch_message(farm_message_id)
            await update_farm_message(message, event_data, farm_type)
            save_farm_data()
            
            embed = discord.Embed(
                title="✅ Пользователь удален из записи",
                color=0x00ff00
            )
            embed.add_field(name="Пользователь", value=member.mention, inline=True)
            embed.add_field(name="Удален из", value=", ".join(removed_from), inline=True)
            
            await ctx.send(embed=embed)
            logger.info(f"Пользователь {member} удален из записи создателем фарма {ctx.author}")
            
            if removed_data:
                farm_config = FARM_TYPES[farm_type]
                role_name = removed_from[0].split('(')[0].strip() if removed_from else "неизвестно"
                await log_farm_action(
                    ctx.guild,
                    'leave',
                    member,
                    removed_data['character'],
                    role_name,
                    farm_type,
                    farm_config['name']
                )
            
            try:
                await member.send(f"🗑️ Вы были удалены из фарма **{FARM_TYPES[farm_type]['name']}**")
            except:
                pass
            
        except discord.NotFound:
            await ctx.send("❌ Сообщение фарма не найдено")
    else:
        await ctx.send(f"❌ {member.mention} не найден в списке записи")

