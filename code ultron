@bot.event
async def on_message(message):
    if message.author.bot:
        return
    
    user_id = message.author.id
    user_stats[user_id]['messages_sent'] += 1
    user_stats[user_id]['last_activity'] = datetime.now()
    
    if should_log_user(message.author):
        add_user_action(
            user_id,
            'message_sent',
            f"Отправил сообщение: {message.content[:50]}...",
            target=None,
            channel=message.channel.name if message.channel else None
        )
    
    if user_stats[user_id]['join_date'] is None:
        user_stats[user_id]['join_date'] = message.author.joined_at or datetime.now()
    
    if isinstance(message.channel, discord.DMChannel) and message.author.id != bot.user.id:
        logger.info(f"📬 Получено ЛС от {message.author} (ID: {message.author.id}): {message.content[:50] if message.content else 'вложения'}")
        
        forward_channel = bot.get_channel(DM_FORWARD_CHANNEL_ID)
        
        if forward_channel:
            try:
                guild = bot.guilds[0] if bot.guilds else None
                member = guild.get_member(message.author.id) if guild else None
                
                embed = discord.Embed(
                    title="📬 Новое сообщение в ЛС",
                    description=message.content if message.content else "*Пустое сообщение*",
                    color=0x7289da,
                    timestamp=datetime.now()
                )
                embed.add_field(name="От", value=f"{message.author.mention} ({message.author.name}#{message.author.discriminator})", inline=True)
                embed.add_field(name="ID", value=message.author.id, inline=True)
                
                if message.attachments:
                    embed.add_field(name="Вложения", value=f"{len(message.attachments)} файлов", inline=True)
                
                embed.set_thumbnail(url=message.author.avatar.url if message.author.avatar else None)
                
                await forward_channel.send(embed=embed)
                
                for attachment in message.attachments:
                    try:
                        await forward_channel.send(f"📎 **Вложение от {message.author.mention}:**\n{attachment.url}")
                    except:
                        pass
                
                logger.info(f"✅ ЛС переслано в канал {forward_channel.name}")
            except Exception as e:
                logger.error(f"❌ Ошибка отправки в канал: {e}")
        else:
            logger.error(f"❌ КАНАЛ ДЛЯ ПЕРЕСЫЛКИ НЕ НАЙДЕН! ID: {DM_FORWARD_CHANNEL_ID}")
    
    await bot.process_commands(message)

