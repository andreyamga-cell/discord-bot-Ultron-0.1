        if should_log_user(ctx.author):
            add_user_action(
                ctx.author.id,
                'bot_cleanup',
                f"Удалил {deleted} сообщений бота",
                target=None,
                channel=ctx.channel.name
            )
        
    except Exception as e:
        await ctx.send(f"❌ Ошибка удаления сообщений: {e}")

