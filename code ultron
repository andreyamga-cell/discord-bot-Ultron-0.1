            title="❌ Ошибка",
            description="У вас нет прав для использования этой команды! Только модераторы могут очищать чат.",
            color=0xff0000
        )
        await ctx.send(embed=embed)
        return
    
    if amount < 1:
        embed = discord.Embed(
            title="❌ Ошибка",
            description="Количество сообщений должно быть больше 0!",
            color=0xff0000
        )
        await ctx.send(embed=embed)
        return
    
    if amount > 100:
        embed = discord.Embed(
            title="❌ Ошибка",
            description="Максимальное количество сообщений для удаления - 100!",
            color=0xff0000
        )
        await ctx.send(embed=embed)
        return
    
    try:
        deleted = await ctx.channel.purge(limit=amount + 1)
        
        if should_log_user(ctx.author):
            add_user_action(
                ctx.author.id,
                'chat_cleared',
                f"Очистил {len(deleted)-1} сообщений в канале #{ctx.channel.name}",
                target=None,
                channel=ctx.channel.name
            )
        
        embed = discord.Embed(
            title="✅ Чат очищен",
            description=f"Удалено **{len(deleted)-1}** сообщений",
            color=0x00ff00,
            timestamp=datetime.now()
        )
        
        embed.add_field(
            name="👮‍♂️ Модератор",
            value=ctx.author.mention,
            inline=True
        )
        
        embed.add_field(
            name="📊 Количество",
            value=str(len(deleted)-1),
            inline=True
        )
        
        embed.add_field(
            name="📝 Канал",
            value=ctx.channel.mention,
            inline=True
        )
        
        msg = await ctx.send(embed=embed)
        await asyncio.sleep(5)
        await msg.delete()
        
        logger.info(f"Пользователь {ctx.author} очистил {len(deleted)-1} сообщений в канале {ctx.channel.name}")
        
        log_message = (
            f"🧹 **Очистка чата**\n"
            f"**Модератор:** {ctx.author.mention} ({ctx.author.name}#{ctx.author.discriminator}) (ID: {ctx.author.id})\n"
            f"**Канал:** #{ctx.channel.name}\n"
            f"**Количество сообщений:** {len(deleted)-1}\n"
            f"**Время:** {datetime.now().strftime('%d.%m.%Y %H:%M:%S')}"
        )
        await send_log(ctx.guild, log_message)
        
    except discord.Forbidden:
        embed = discord.Embed(
            title="❌ Ошибка",
            description="У меня нет прав для удаления сообщений в этом канале!",
            color=0xff0000
        )
        await ctx.send(embed=embed)
        
    except discord.HTTPException as e:
        embed = discord.Embed(
            title="❌ Ошибка",
            description=f"Не удалось удалить сообщения: {str(e)}",
            color=0xff0000
        )
        await ctx.send(embed=embed)
    except Exception as e:
        embed = discord.Embed(
            title="❌ Ошибка",
            description=f"Произошла ошибка: {str(e)}",
            color=0xff0000
        )
        await ctx.send(embed=embed)

