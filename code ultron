        for w in warnings_to_remove:
            if w['end_time'] > datetime.now():
                role_name = WARNING_ROLES[level]
                role = discord.utils.get(ctx.guild.roles, name=role_name)
                if role and role in member.roles:
                    await member.remove_roles(role)
                
                if w.get('had_admin'):
                    admin_role = discord.utils.get(ctx.guild.roles, name="Администратор")
                    if admin_role and admin_role not in member.roles:
                        await member.add_roles(admin_role)
                
                active_warnings[member.id] = [warn for warn in active_warnings[member.id] if warn['warning_id'] != w['warning_id']]
                
                await ctx.send(f"✅ Предупреждение уровня {level} снято с {member.mention}")
                logger.info(f"Предупреждение уровня {level} снято с пользователя {member}")
                
                if should_log_user(ctx.author):
                    add_user_action(
                        ctx.author.id,
                        'warn_removed',
                        f"Снял предупреждение уровня {level} с пользователя {member.name}",
                        target=member.id,
                        channel=None
                    )
                
                log_message = (
                    f"✅ **Снято предупреждение**\n"
                    f"**Пользователь:** {member.mention} ({member.name}#{member.discriminator}) (ID: {member.id})\n"
                    f"**Кто снял:** {ctx.author.mention} ({ctx.author.name}#{ctx.author.discriminator}) (ID: {ctx.author.id})\n"
                    f"**Уровень:** {level}\n"
                    f"**Время:** {datetime.now().strftime('%d.%m.%Y %H:%M:%S')}"
                )
                await send_log(ctx.guild, log_message)
                
                save_warnings()
                
                try:
                    await member.send(f"✅ Ваше предупреждение уровня {level} было снято администратором.")
                except:
                    pass
                return
        
        await ctx.send(f"❌ Предупреждение уровня {level} уже истекло и не может быть снято вручную!")
        
    else:
        removed_count = 0
        for warning in active_warnings[member.id][:]:
            if warning['end_time'] > datetime.now():
                role_name = WARNING_ROLES[warning['level']]
                role = discord.utils.get(ctx.guild.roles, name=role_name)
                if role and role in member.roles:
                    await member.remove_roles(role)
                
                if warning.get('had_admin'):
                    admin_role = discord.utils.get(ctx.guild.roles, name="Администратор")
                    if admin_role and admin_role not in member.roles:
                        await member.add_roles(admin_role)
                
                active_warnings[member.id].remove(warning)
                removed_count += 1
        
        if removed_count > 0:
            if not active_warnings[member.id]:
                del active_warnings[member.id]
            
            await ctx.send(f"✅ {removed_count} активных предупреждений снято с {member.mention}")
            logger.info(f"Снято {removed_count} предупреждений с пользователя {member}")
            
            if should_log_user(ctx.author):
                add_user_action(
                    ctx.author.id,
                    'warn_removed_all',
                    f"Снял {removed_count} предупреждений с пользователя {member.name}",
                    target=member.id,
                    channel=None
                )
            
            log_message = (
                f"✅ **Сняты активные предупреждения**\n"
                f"**Пользователь:** {member.mention} ({member.name}#{member.discriminator}) (ID: {member.id})\n"
                f"**Кто снял:** {ctx.author.mention} ({ctx.author.name}#{ctx.author.discriminator}) (ID: {ctx.author.id})\n"
                f"**Количество:** {removed_count}\n"
                f"**Время:** {datetime.now().strftime('%d.%m.%Y %H:%M:%S')}"
            )
            await send_log(ctx.guild, log_message)
            
            save_warnings()
            
            try:
                await member.send(f"✅ Ваши активные предупреждения были сняты администратором.")
            except:
                pass
        else:
            await ctx.send(f"❌ У {member.mention} нет активных предупреждений для снятия")

