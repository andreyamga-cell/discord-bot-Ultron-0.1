@bot.command(name='farmtop')
async def farm_top_command(ctx, limit: int = 10):
    if not is_moderator(ctx):
        embed = discord.Embed(
            title="❌ Ошибка",
            description="У вас нет прав для использования этой команды! Только модераторы могут смотреть топ фарма.",
            color=0xff0000
        )
        await ctx.send(embed=embed)
        return
    
    if limit > 20:
        limit = 20
    
    user_totals = {}
    for user_id, stats in farm_stats.items():
        total = sum(stats.values())
        if total > 0:
            user_totals[user_id] = total
    
    if not user_totals:
        embed = discord.Embed(
            title="🏆 Топ фармеров",
            description="**Нет данных о фарме**",
            color=0x7289da
        )
        embed.add_field(
            name="ℹ️ Информация",
            value="Пока никто не фармил на сервере.",
            inline=False
        )
        await ctx.send(embed=embed)
        return
    
    sorted_users = sorted(user_totals.items(), key=lambda x: x[1], reverse=True)[:limit]
    
    embed = discord.Embed(
        title="🏆 Топ фармеров",
        description=f"Топ {len(sorted_users)} пользователей по количеству завершенных фармов",
        color=0xff9900,
        timestamp=datetime.now()
    )
    
    medals = ["🥇", "🥈", "🥉"]
    
