async def restore_active_warnings():
    if not bot.guilds:
        return
        
    guild = bot.guilds[0]
    
    for user_id, warnings in list(active_warnings.items()):
        member = guild.get_member(user_id)
        if not member:
            continue
            
        for warning in warnings[:]:
            if warning['end_time'] <= datetime.now():
                active_warnings[user_id].remove(warning)
                continue
            
            role = discord.utils.get(guild.roles, name=warning['role_name'])
            if role and role not in member.roles:
                await member.add_roles(role)
            
            delay_seconds = (warning['end_time'] - datetime.now()).total_seconds()
            if delay_seconds > 0:
                bot.loop.create_task(
                    remove_warning_after_delay(member, role, delay_seconds, user_id, warning['level'], warning['warning_id'])
                )
            
            logger.info(f"Восстановлено предупреждение уровня {warning['level']} для {member}")
        
        if not active_warnings[user_id]:
            del active_warnings[user_id]

async def restore_farm_messages():
    if not bot.guilds:
        return
    
    guild = bot.guilds[0]
    restored_count = 0
    
    for message_id, farm_data in list(farm_messages.items()):
