def is_moderator(ctx_or_user):
    if hasattr(ctx_or_user, 'author'):
        user = ctx_or_user.author
        ctx = ctx_or_user
    else:
        user = ctx_or_user
        ctx = None
    
    if user.id in MODERATOR_USER_IDS:
        return True
    
    if ctx and hasattr(ctx, 'guild') and ctx.guild:
        member = ctx.guild.get_member(user.id)
        if member:
            for role in member.roles:
                if role.id in MODERATOR_ROLE_IDS:
                    return True
    
    if hasattr(user, 'guild_permissions') and user.guild_permissions.administrator:
        return True
    
    if ctx and ctx.guild:
        member = ctx.guild.get_member(user.id)
        if member and member.guild_permissions.administrator:
            return True
    
    return False

def can_verify(ctx):
    if ctx.author.id in MODERATOR_USER_IDS:
        return True
    
    if hasattr(ctx.author, 'roles'):
        for role in ctx.author.roles:
            if role.id == MODERATOR_VERIFY_ROLE_ID:
                return True
    
    return ctx.author.guild_permissions.administrator

def is_farm_creator(ctx):
    if is_moderator(ctx):
        return True
    
    if hasattr(ctx.author, 'roles'):
        for role in ctx.author.roles:
            if role.id == FARM_CREATOR_ROLE_ID:
                return True
    
    return False

