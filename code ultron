@bot.command(name='repeat')
async def repeat_message(ctx, count: int, interval: str, channel_id: int, *, message: str):
    if not is_moderator(ctx):
        embed = discord.Embed(
            title="❌ Ошибка",
            description="У вас нет прав для использования этой команды! Только модераторы могут создавать повторяющиеся сообщения.",
            color=0xff0000
        )
        await ctx.send(embed=embed)
        return
    
    time_pattern = re.compile(r'(\d+)([smhd])')
    match = time_pattern.match(interval.lower())
    
    if not match:
        await ctx.send("❌ Неверный формат интервала. Используйте: 30s, 30m, 1h, 1d")
        return
    
    time_value = int(match.group(1))
    time_unit = match.group(2)
    
    time_units = {
        's': 1,
        'm': 60,
        'h': 3600,
        'd': 86400
    }
    
    if time_unit not in time_units:
        await ctx.send("❌ Неверная единица времени. Используйте: s (секунды), m (минуты), h (часы), d (дни)")
        return
    
    total_seconds = time_value * time_units[time_unit]
    
    channel = ctx.guild.get_channel(channel_id)
    if not channel:
        await ctx.send("❌ Канал не найден!")
        return
    
    if not channel.permissions_for(ctx.guild.me).send_messages:
        await ctx.send("❌ У бота нет прав для отправки сообщений в указанный канал!")
        return
    
    task_id = f"{ctx.author.id}_{datetime.now().timestamp()}"
    
    repeating_messages[task_id] = {
        'count': count,
        'interval': total_seconds,
        'channel_id': channel_id,
        'message': message,
        'remaining': count,
        'author': ctx.author.id,
        'started_at': datetime.now()
    }
    
    if time_unit == 's':
        time_display = f"{time_value} секунд"
    elif time_unit == 'm':
        time_display = f"{time_value} минут"
    elif time_unit == 'h':
        time_display = f"{time_value} часов"
    elif time_unit == 'd':
        time_display = f"{time_value} дней"
    
    embed = discord.Embed(
        title="🔄 Запланировано повторяющееся сообщение",
        color=0x00ff00,
        timestamp=datetime.now()
    )
    
    embed.add_field(name="📊 Количество отправок", value=count, inline=True)
    embed.add_field(name="⏰ Интервал", value=time_display, inline=True)
    embed.add_field(name="📝 Канал", value=channel.mention, inline=True)
    embed.add_field(name="💬 Сообщение", value=message[:100] + "..." if len(message) > 100 else message, inline=False)
    embed.add_field(name="👤 Создал", value=ctx.author.mention, inline=True)
    
    embed.set_footer(text=f"ID задачи: {task_id}")
    
    await ctx.send(embed=embed)
    logger.info(f"Создана повторяющаяся задача: {count} раз каждые {time_display} в канал {channel_id}")
    
    bot.loop.create_task(
        execute_repeating_message(task_id, count, total_seconds, channel_id, message)
    )

async def execute_repeating_message(task_id, count, interval, channel_id, message):
    try:
        guild = bot.guilds[0] if bot.guilds else None
        if not guild:
            logger.error("Гильдия не найдена для повторяющегося сообщения")
            return
        
        channel = guild.get_channel(channel_id)
        if not channel:
            logger.error(f"Канал {channel_id} не найден")
            return
        
        for i in range(count):
            if task_id not in repeating_messages:
                break
                
            try:
                await channel.send(message)
                logger.info(f"Отправлено повторяющееся сообщение {i+1}/{count} в канал {channel.name}")
                
                repeating_messages[task_id]['remaining'] = count - i - 1
                
                if i < count - 1:
                    await asyncio.sleep(interval)
                    
            except discord.Forbidden:
                logger.error(f"Нет прав для отправки сообщения в канал {channel.name}")
                break
            except Exception as e:
                logger.error(f"Ошибка отправки повторяющегося сообщения: {e}")
                break
        
        if task_id in repeating_messages:
            del repeating_messages[task_id]
            logger.info(f"Завершена повторяющаяся задача {task_id}")
            
    except Exception as e:
        logger.error(f"Ошибка в выполнении повторяющейся задачи: {e}")

