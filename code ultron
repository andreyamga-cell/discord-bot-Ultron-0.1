def get_unix_timestamp(time_str):
    msk_tz = pytz.timezone('Europe/Moscow')
    now = datetime.now(msk_tz)
    
    try:
        hour, minute = map(int, time_str.split(':'))
        event_time = now.replace(hour=hour, minute=minute, second=0, microsecond=0)
        
        if event_time < now:
            event_time += timedelta(days=1)
        
        utc_time = event_time.astimezone(pytz.UTC)
        timestamp = int(utc_time.timestamp())
        
        return timestamp, event_time
    except Exception as e:
        logger.error(f"Ошибка получения timestamp: {e}")
        return None, None

def format_time_info(time_str):
    timestamp, event_time = get_unix_timestamp(time_str)
    
    if timestamp:
        return {
            'full': f"<t:{timestamp}:F>",
            'time': f"<t:{timestamp}:t>",
            'date': f"<t:{timestamp}:d>",
            'relative': f"<t:{timestamp}:R>"
        }
    return None

