class VerifyConfirmView(discord.ui.View):
    def __init__(self, channel_id, user_id):
        super().__init__(timeout=120)
        self.channel_id = channel_id
        self.user_id = user_id
    
    @discord.ui.button(label="✅ Да", style=discord.ButtonStyle.success)
    async def confirm_yes(self, interaction: discord.Interaction, button: discord.ui.Button):
        await interaction.response.defer()
        
        if not can_verify(interaction):
            await interaction.followup.send("❌ У вас нет прав для верификации!", ephemeral=True)
            return
        
        channel = interaction.guild.get_channel(self.channel_id)
        user = interaction.guild.get_member(self.user_id)
        
        if not user:
            await interaction.followup.send("❌ Пользователь не найден!", ephemeral=True)
            return
        
        verify_role = interaction.guild.get_role(VERIFY_ROLE_ID)
        verified_role = interaction.guild.get_role(VERIFIED_ROLE_ID)
        
        if verified_role:
            await user.add_roles(verified_role)
        if verify_role and verify_role in user.roles:
            await user.remove_roles(verify_role)
        
        await channel.set_permissions(user, view_channel=False)
        
        archive_category = interaction.guild.get_channel(VERIFY_ARCHIVE_CATEGORY_ID)
        if archive_category:
            await channel.edit(category=archive_category)
        
        ticket_data = active_tickets.get(self.channel_id, {})
        ign = ticket_data.get('ign', 'unknown')
        new_name = f"✅-{ign.lower().replace(' ', '-')[:50]}"
        try:
            await channel.edit(name=new_name)
        except:
            pass
        
        embed = discord.Embed(
            title="✅ Пользователь верифицирован!",
            description=f"{user.mention} успешно прошел верификацию!",
            color=0x00ff00
        )
        embed.add_field(name="IGN", value=ign, inline=True)
        embed.add_field(name="Верифицировал", value=interaction.user.mention, inline=True)
        await channel.send(embed=embed)
        
        if self.channel_id in active_tickets:
            del active_tickets[self.channel_id]
        
        for child in self.children:
            child.disabled = True
        await interaction.message.edit(view=self)
        
        await interaction.followup.send("✅ Пользователь верифицирован!", ephemeral=True)
        logger.info(f"Пользователь {user} верифицирован модератором {interaction.user}")
    
    @discord.ui.button(label="❌ Нет", style=discord.ButtonStyle.danger)
    async def confirm_no(self, interaction: discord.Interaction, button: discord.ui.Button):
        await interaction.response.defer()
        
        if not can_verify(interaction):
            await interaction.followup.send("❌ У вас нет прав!", ephemeral=True)
            return
        
        for child in self.children:
            child.disabled = True
        await interaction.message.edit(view=self)
        
        await interaction.followup.send("❌ Верификация отменена. Продолжайте общение в тикете.", ephemeral=True)

