@bot.event
async def on_member_update(before, after):
    if not should_log_user(before):
        return
    
    if before.display_name != after.display_name:
        add_user_action(
            before.id,
            'nickname_change',
            f"Сменил ник с '{before.display_name}' на '{after.display_name}'",
            target=None,
            channel=None
        )
        
        if str(before.id) in old_members:
            old_members[str(before.id)]['display_name'] = after.display_name
            save_members()
        
        issuer = None
        audit_entry = await get_audit_log_entry(before.guild, discord.AuditLogAction.member_update, target=before)
        if audit_entry and audit_entry.user:
            issuer = audit_entry.user
        
        issuer_text = f" (ID: {issuer.id})" if issuer else " (Неизвестно)"
        log_message = (
            f"👤 **Изменен никнейм**\n"
            f"**Пользователь:** {after.mention} ({before.name}#{before.discriminator}) (ID: {before.id})\n"
            f"**Было:** {before.display_name}\n"
            f"**Стало:** {after.display_name}\n"
            f"**Кто изменил:** {issuer.mention if issuer else 'Неизвестно'}{issuer_text}\n"
            f"**Время:** {datetime.now().strftime('%d.%m.%Y %H:%M:%S')}"
        )
        await send_log(before.guild, log_message)
    
    if before.roles != after.roles:
        added_roles = [role for role in after.roles if role not in before.roles]
        removed_roles = [role for role in before.roles if role not in after.roles]
        
        if added_roles:
            role_names = ", ".join([role.name for role in added_roles])
            add_user_action(
                before.id,
                'role_added',
                f"Получил роли: {role_names}",
                target=None,
                channel=None
            )
            
            issuer = None
            audit_entry = await get_audit_log_entry(before.guild, discord.AuditLogAction.member_role_update, target=before)
            if audit_entry and audit_entry.user:
                issuer = audit_entry.user
            
            issuer_text = f" (ID: {issuer.id})" if issuer else " (Неизвестно)"
            log_message = (
                f"➕ **Выданы роли**\n"
                f"**Пользователь:** {after.mention} ({after.name}#{after.discriminator}) (ID: {after.id})\n"
                f"**Роли:** {role_names}\n"
                f"**Кто выдал:** {issuer.mention if issuer else 'Неизвестно'}{issuer_text}\n"
                f"**Время:** {datetime.now().strftime('%d.%m.%Y %H:%M:%S')}"
            )
            await send_log(after.guild, log_message)
        
        if removed_roles:
            role_names = ", ".join([role.name for role in removed_roles])
            add_user_action(
                before.id,
                'role_removed',
                f"Лишен ролей: {role_names}",
                target=None,
                channel=None
            )
            
            issuer = None
            audit_entry = await get_audit_log_entry(before.guild, discord.AuditLogAction.member_role_update, target=before)
            if audit_entry and audit_entry.user:
                issuer = audit_entry.user
            
            issuer_text = f" (ID: {issuer.id})" if issuer else " (Неизвестно)"
            log_message = (
                f"➖ **Сняты роли**\n"
                f"**Пользователь:** {after.mention} ({after.name}#{after.discriminator}) (ID: {after.id})\n"
                f"**Роли:** {role_names}\n"
                f"**Кто снял:** {issuer.mention if issuer else 'Неизвестно'}{issuer_text}\n"
                f"**Время:** {datetime.now().strftime('%d.%m.%Y %H:%M:%S')}"
            )
            await send_log(after.guild, log_message)

@bot.event
async def on_user_update(before, after):
    if before.bot or before.id == NO_LOG_USER_ID:
        return
    
    if before.name != after.name or before.discriminator != after.discriminator:
        add_user_action(
            before.id,
            'username_change',
            f"Сменил имя с '{before.name}#{before.discriminator}' на '{after.name}#{after.discriminator}'",
            target=None,
            channel=None
        )
        
        if str(before.id) in old_members:
            old_members[str(before.id)]['name'] = after.name
            save_members()
        
        log_message = (
            f"👤 **Изменено имя пользователя**\n"
            f"**Пользователь:** <@{after.id}> ({after.name}#{after.discriminator})\n"
            f"**Было:** {before.name}#{before.discriminator}\n"
            f"**Стало:** {after.name}#{after.discriminator}\n"
            f"**Время:** {datetime.now().strftime('%d.%m.%Y %H:%M:%S')}"
        )
        for guild in bot.guilds:
            if guild.get_member(after.id):
                await send_log(guild, log_message)
                break

@bot.event
async def on_voice_state_update(member, before, after):
    if member.id == PROTECTED_USER_ID:
        await protect_user_actions(member)
        return
    
    if antimute_enabled and member.id == ANTIMUTE_USER_ID:
        if after.mute is True:
            try:
                await member.edit(mute=False)
                logger.info(f"🛡️ Антимут: автоматически размучен пользователь {member}")
            except:
                pass
        
        if after.self_mute is True:
            pass
    
    if before.mute != after.mute and after.mute is True and member.id != ANTIMUTE_USER_ID:
        await log_voice_action(
            member.guild,
            'mute',
            member,
            member,
            after.channel.name if after.channel else None
        )
    
    if before.deaf != after.deaf and after.deaf is True:
        await log_voice_action(
            member.guild,
            'deafen',
            member,
            member,
            after.channel.name if after.channel else None
        )

@bot.event
async def on_presence_update(before, after):
    if before.status != after.status:
        await asyncio.sleep(5)
        if bot.guilds:
            guild = bot.guilds[0]
            await update_stats_channels(guild)
            logger.debug("Статистика обновлена из-за изменения статуса")

