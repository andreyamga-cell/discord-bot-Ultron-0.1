    await interaction.message.delete()
    
    farm_config = FARM_TYPES[farm_type]
    event_data = {}
    
    for role_key in farm_config['roles'].keys():
        event_data[role_key] = []
    
    embed = create_farm_embed(event_data, farm_type)
    
    if 'team1_' in list(farm_config['roles'].keys())[0]:
        view = TeamFarmRoleSelectionView(0, farm_type)
    else:
        view = RoleSelectionView(0, farm_type)
    
    if is_farm_creator(interaction):
        manage_view = FarmUserManagementView(0, farm_type)
        for item in manage_view.children:
            view.add_item(item)
    
    message = await interaction.channel.send(embed=embed, view=view)
    
    view.message_id = message.id
    if hasattr(manage_view, 'message_id'):
        manage_view.message_id = message.id
    farm_messages[message.id] = {
        'data': event_data,
        'type': farm_type
    }
    
    save_farm_data()
    
    await interaction.response.send_message(f"✅ Создан лист для {farm_config['name']}!", ephemeral=True, delete_after=5)

