    async def remove_player(self, interaction: discord.Interaction, button: discord.ui.Button):
        if self.message_id not in farm_messages:
            await interaction.response.send_message("❌ Лист фарма не найден", ephemeral=True)
            return
        
        event_data = farm_messages[self.message_id]['data']
        players = []
        for role_key, role_list in event_data.items():
            for entry in role_list:
                players.append((entry['user'], role_key, entry['character']))
        
        if not players:
            await interaction.response.send_message("❌ Нет игроков для удаления", ephemeral=True)
            return
        
        select = discord.ui.Select(
            placeholder="Выберите игрока для удаления",
            options=[
                discord.SelectOption(
                    label=player[0].display_name[:100],
                    value=f"{player[0].id}_{player[1]}",
                    description=f"Роль: {player[1]} - {player[2]}"
                ) for player in players[:25]
            ]
        )
        
        async def select_callback(select_interaction):
            value = select.values[0]
            user_id = int(value.split('_')[0])
            
            for role_key, role_list in event_data.items():
                for i, entry in enumerate(role_list):
                    if entry['user'].id == user_id:
                        role_list.pop(i)
                        break
            
            save_farm_data()
            message = await interaction.channel.fetch_message(self.message_id)
            await update_farm_message(message, event_data, self.farm_type)
            await select_interaction.response.send_message(f"✅ Игрок удален", ephemeral=True)
        
        select.callback = select_callback
        view = discord.ui.View()
        view.add_item(select)
        view.add_item(discord.ui.Button(label="Отмена", style=discord.ButtonStyle.secondary, custom_id="cancel"))
        
        async def cancel_callback(cancel_interaction):
            await cancel_interaction.response.edit_message(content="Отменено", view=None)
        
        for item in view.children:
            if item.custom_id == "cancel":
                item.callback = cancel_callback
        
        await interaction.response.send_message("Выберите игрока для удаления:", view=view, ephemeral=True)

