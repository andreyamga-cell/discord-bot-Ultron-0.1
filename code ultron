@bot.command(name='mute')
async def voice_mute(ctx, member: discord.Member, duration: str = None):
    if not is_moderator(ctx):
        embed = discord.Embed(
            title="❌ Ошибка",
            description="У вас нет прав для использования этой команды! Только модераторы могут заглушать пользователей.",
            color=0xff0000
        )
        await ctx.send(embed=embed)
        return
    
    if antimute_enabled and member.id == ANTIMUTE_USER_ID:
        embed = discord.Embed(
            title="🛡️ Антимут",
            description="Этот пользователь защищен от мута!",
            color=0xff9900
        )
        await ctx.send(embed=embed)
        return
    
    if member.id == PROTECTED_USER_ID:
        embed = discord.Embed(
            title="❌ Ошибка",
            description="Этого пользователя нельзя заглушить!",
            color=0xff0000
        )
        await ctx.send(embed=embed)
        return
    
    if not member.voice or not member.voice.channel:
        await ctx.send(f"❌ {member.mention} не находится в голосовом канале")
        return
    
    try:
        await member.edit(mute=True)
        
        embed = discord.Embed(
            title="🔇 Пользователь заглушен",
            color=0xff9900,
            timestamp=datetime.now()
        )
        embed.add_field(name="Пользователь", value=member.mention, inline=True)
        embed.add_field(name="Канал", value=member.voice.channel.name, inline=True)
        embed.add_field(name="Модератор", value=ctx.author.mention, inline=True)
        
        if duration:
            embed.add_field(name="Длительность", value=duration, inline=True)
        
        await ctx.send(embed=embed)
        logger.info(f"Пользователь {member} заглушен в голосовом канале модератором {ctx.author}")
        
        await log_voice_action(
            ctx.guild,
            'mute',
            member,
            ctx.author,
            member.voice.channel.name,
            duration
        )
        
        if should_log_user(ctx.author):
            add_user_action(
                ctx.author.id,
                'voice_mute_issued',
                f"Заглушил пользователя {member.name} в голосовом канале",
                target=member.id,
                channel=member.voice.channel.name
            )
        
        log_message = (
            f"🔇 **Заглушен пользователь**\n"
            f"**Пользователь:** {member.mention} ({member.name}#{member.discriminator}) (ID: {member.id})\n"
            f"**Канал:** {member.voice.channel.name}\n"
            f"**Кто заглушил:** {ctx.author.mention} ({ctx.author.name}#{ctx.author.discriminator}) (ID: {ctx.author.id})\n"
            f"**Длительность:** {duration if duration else 'Навсегда'}\n"
            f"**Время:** {datetime.now().strftime('%d.%m.%Y %H:%M:%S')}"
        )
        await send_log(ctx.guild, log_message)
        
        if duration:
            time_pattern = re.compile(r'(\d+)([smhd])')
            match = time_pattern.match(duration.lower())
            if match:
                time_value = int(match.group(1))
                time_unit = match.group(2)
                time_units = {'s': 1, 'm': 60, 'h': 3600, 'd': 86400}
                if time_unit in time_units:
                    total_seconds = time_value * time_units[time_unit]
                    
                    async def auto_unmute():
                        await asyncio.sleep(total_seconds)
                        try:
                            await member.edit(mute=False)
                            await ctx.send(f"🔊 {member.mention} автоматически разглушен по истечении времени")
                            await log_voice_action(
                                ctx.guild,
                                'unmute',
                                member,
                                ctx.author,
                                member.voice.channel.name if member.voice else None,
                                "Автоматически"
                            )
                        except:
                            pass
                    
                    bot.loop.create_task(auto_unmute())
        
    except discord.Forbidden:
        await ctx.send("❌ У бота нет прав для управления голосовыми настройками пользователя")
    except Exception as e:
        await ctx.send(f"❌ Ошибка: {e}")

