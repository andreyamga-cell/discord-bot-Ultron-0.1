class VerificationStartView(discord.ui.View):
    def __init__(self):
        super().__init__(timeout=None)
    
    @discord.ui.button(label="🎫 Создать тикет на верификацию", style=discord.ButtonStyle.primary, emoji="🎫")
    async def create_ticket(self, interaction: discord.Interaction, button: discord.ui.Button):
        for channel_id, ticket_data in active_tickets.items():
            if ticket_data['user_id'] == interaction.user.id:
                channel = interaction.guild.get_channel(channel_id)
                if channel:
                    await interaction.response.send_message(
                        f"❌ У вас уже есть открытый тикет: {channel.mention}\nЗакройте его, чтобы создать новый.",
                        ephemeral=True
                    )
                    return
        
        verify_role = interaction.guild.get_role(VERIFY_ROLE_ID)
        verified_role = interaction.guild.get_role(VERIFIED_ROLE_ID)
        
        if verified_role and verified_role in interaction.user.roles:
            await interaction.response.send_message(
                "✅ Вы уже верифицированы и имеете доступ к серверу!",
                ephemeral=True
            )
            return
        
        global ticket_counter
        ticket_name = f"тикет-{ticket_counter}"
        
        category = interaction.guild.get_channel(VERIFY_CATEGORY_ID)
        
        overwrites = {
            interaction.guild.default_role: discord.PermissionOverwrite(view_channel=False),
            interaction.user: discord.PermissionOverwrite(view_channel=True, send_messages=True, read_message_history=True),
            interaction.guild.me: discord.PermissionOverwrite(view_channel=True, send_messages=True, read_message_history=True)
        }
        
        mod_verify_role = interaction.guild.get_role(MODERATOR_VERIFY_ROLE_ID)
        if mod_verify_role:
            overwrites[mod_verify_role] = discord.PermissionOverwrite(view_channel=True, send_messages=True, read_message_history=True)
        
        for mod_role_id in MODERATOR_ROLE_IDS:
            mod_role = interaction.guild.get_role(mod_role_id)
            if mod_role:
                overwrites[mod_role] = discord.PermissionOverwrite(view_channel=True, send_messages=True, read_message_history=True)
        
        for mod_user_id in MODERATOR_USER_IDS:
            mod_user = interaction.guild.get_member(mod_user_id)
            if mod_user:
                overwrites[mod_user] = discord.PermissionOverwrite(view_channel=True, send_messages=True, read_message_history=True)
        
        ticket_channel = await interaction.guild.create_text_channel(
            name=ticket_name,
            category=category,
            overwrites=overwrites
        )
        
        active_tickets[ticket_channel.id] = {
            'user_id': interaction.user.id,
            'ign': None,
            'step': 'ign'
        }
        
        ticket_counter += 1
        save_ticket_counter()
        
        embed = discord.Embed(
            title="🎫 Тикет верификации",
            description=f"Добро пожаловать, {interaction.user.mention}!",
            color=0x00ff00
        )
        embed.add_field(
            name="📝 Шаг 1",
            value="Пожалуйста, укажите ваш никнейм (IGN) в игре **Marvel Rivals**.\n\n"
                  "Используйте меню ниже, чтобы ввести ваш никнейм.",
            inline=False
        )
        embed.set_footer(text="Ваш ответ увидят только модераторы")
        
        view = IGNInputView(ticket_channel.id)
        await ticket_channel.send(embed=embed, view=view)
        
        mod_mention = ""
        if mod_verify_role:
            mod_mention = mod_verify_role.mention + " "
        for mod_role_id in MODERATOR_ROLE_IDS:
            mod_role = interaction.guild.get_role(mod_role_id)
            if mod_role:
                mod_mention += mod_role.mention + " "
        
        await ticket_channel.send(f"{mod_mention} Создан новый тикет для верификации {interaction.user.mention}")
        
        await interaction.response.send_message(
            f"✅ Тикет для верификации создан: {ticket_channel.mention}",
            ephemeral=True
        )
        
        logger.info(f"Создан тикет {ticket_channel.name} для пользователя {interaction.user}")

