async def send_initial_messages():
    channel = bot.get_channel(CHANNEL_ID)
    if channel is None:
        logger.error(f"Канал с ID {CHANNEL_ID} не найден!")
        return
    
    async for message in channel.history(limit=100):
        if message.author == bot.user:
            await message.delete()
    
    for region, timezone in TIMEZONES.items():
        embed = create_time_embed(region, timezone)
        message = await channel.send(embed=embed)
        message_ids[region] = message.id
        logger.info(f"Отправлено сообщение для {region}")
    
    logger.info("Все сообщения с временем успешно отправлены!")

@tasks.loop(minutes=5)
async def update_time():
    logger.info("Обновление времени...")
    
    channel = bot.get_channel(CHANNEL_ID)
    if channel is None:
        logger.error("Канал не найден!")
        return
    
    for region, timezone in TIMEZONES.items():
        message_id = message_ids.get(region)
        if message_id:
            try:
                message = await channel.fetch_message(message_id)
                embed = create_time_embed(region, timezone)
                await message.edit(embed=embed)
                logger.info(f"Обновлено время для {region}")
                
            except discord.NotFound:
                logger.warning(f"Сообщение для {region} не найдено, отправляем новое...")
                embed = create_time_embed(region, timezone)
                message = await channel.send(embed=embed)
                message_ids[region] = message.id
                
            except Exception as e:
                logger.error(f"Ошибка при обновлении времени для {region}: {e}")

