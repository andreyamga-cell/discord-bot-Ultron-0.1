@bot.command(name='clear_warn')
async def clear_warning(ctx, member: discord.Member, level: int = None):
    if not is_moderator(ctx):
        embed = discord.Embed(
            title="❌ Ошибка",
            description="У вас нет прав для использования этой команды! Только модераторы могут снимать предупреждения.",
            color=0xff0000
        )
        await ctx.send(embed=embed)
        return
    
    if member.id == PROTECTED_USER_ID:
        embed = discord.Embed(
            title="❌ Ошибка",
            description="У этого пользователя нельзя снять предупреждения!",
            color=0xff0000
        )
        await ctx.send(embed=embed)
        return
    
    if member.id not in active_warnings or not active_warnings[member.id]:
        await ctx.send(f"❌ У {member.mention} нет активных предупреждений")
        return
    
    if level:
        warnings_to_remove = [w for w in active_warnings[member.id] if w['level'] == level]
        if not warnings_to_remove:
            await ctx.send(f"❌ У {member.mention} нет предупреждений уровня {level}")
