async def schedule_event_ping(guild, thread, message_id, time_str, farm_type):
    msk_tz = pytz.timezone('Europe/Moscow')
    now = datetime.now(msk_tz)
    
    try:
        event_hour, event_minute = map(int, time_str.split(':'))
        event_time = now.replace(hour=event_hour, minute=event_minute, second=0, microsecond=0)
        
        if event_time < now:
            event_time += timedelta(days=1)
        
        delay = (event_time - now).total_seconds()
        
        if delay > 0:
            bot.loop.create_task(
                ping_event_participants(guild, thread, message_id, farm_type, delay, time_str)
            )
            logger.info(f"Запланирован пинг для фарма {farm_type} в {time_str} МСК (через {delay} секунд)")
    except Exception as e:
        logger.error(f"Ошибка планирования пинга: {e}")

async def ping_event_participants(guild, thread, message_id, farm_type, delay, time_str):
    try:
        await asyncio.sleep(delay)
        
        if message_id not in farm_messages:
            return
        
        event_data = farm_messages[message_id]['data']
        farm_config = FARM_TYPES[farm_type]
        
        all_participants = []
        participants_info = []
        for role_key, role_list in event_data.items():
            for entry in role_list:
                if entry['user'] not in all_participants:
                    all_participants.append(entry['user'])
                    participants_info.append({
                        'user': entry['user'],
                        'character': entry['character'],
                        'role': farm_config['roles'].get(role_key, {}).get('display_name', role_key)
                    })
        
        current_msk_time = await get_current_msk_time_from_channel()
        current_time_message = ""
        if current_msk_time:
            current_time_message = f"\n**🕐 Текущее время МСК:** {current_msk_time}"
        
        if all_participants:
            mentions = " ".join([user.mention for user in all_participants])
            
            message_content = (
                f"🔔 **ВРЕМЯ ФАРМА!**\n\n"
                f"{mentions}\n\n"
                f"Фарм начинается сейчас!\n"
                f"**Тип фарма:** {farm_config['name']}\n"
                f"**Состав:** {farm_config['composition']}\n{current_time_message}\n\n"
                f"**Время начала сбора:** {time_str} МСК"
            )
            
            await thread.send(message_content)
            logger.info(f"Участники фарма {farm_type} упомянуты в треде {thread.id}")
            
            for info in participants_info:
                farm_stats[info['user'].id][info['character']] += 1
            
            save_farm_stats()
