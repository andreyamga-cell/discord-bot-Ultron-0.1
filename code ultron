class MembersPaginationView(discord.ui.View):
    def __init__(self, members_list, page, total_pages, members_per_page=10):
        super().__init__(timeout=120)
        self.members_list = members_list
        self.current_page = page
        self.total_pages = total_pages
        self.members_per_page = members_per_page
    
    @discord.ui.button(label="◀️ Назад", style=discord.ButtonStyle.secondary, custom_id="prev_members")
    async def prev_button(self, interaction: discord.Interaction, button: discord.ui.Button):
        if self.current_page > 1:
            self.current_page -= 1
            await self.update_message(interaction)
    
    @discord.ui.button(label="➡️ Вперед", style=discord.ButtonStyle.secondary, custom_id="next_members")
    async def next_button(self, interaction: discord.Interaction, button: discord.ui.Button):
